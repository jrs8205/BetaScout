<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- The session cookie (settings DataStore) and the account-scoped scrape
         observations (Room DB, keyed by the account email) must never leave the
         device via cloud backup or device-to-device transfer. -->
    <cloud-backup>
        <exclude
            domain="file"
            path="datastore/settings.preferences_pb" />
        <exclude
            domain="database"
            path="betascout.db" />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="file"
            path="datastore/settings.preferences_pb" />
        <exclude
            domain="database"
            path="betascout.db" />
    </device-transfer>
</data-extraction-rules>
