<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- The session cookie (settings DataStore) and the account-scoped scrape
         observations (Room DB) must never leave the device via backup. -->
    <exclude
        domain="file"
        path="datastore/settings.preferences_pb" />
    <exclude
        domain="database"
        path="betascout.db" />
</full-backup-content>
