    <!-- Onboarding -->
    <string name="onboarding_title">Welcome to BetaScout</string>
    <string name="onboarding_what">BetaScout scans your installed apps, shows which ones are known to have a Google Play beta program, opens the opt-in page for you and reminds you to re-check watched apps.</string>
    <string name="onboarding_honesty_title">What BetaScout does not do</string>
    <string name="onboarding_honesty">It never joins beta programs on your behalf. Once you sign in with Google, your memberships and each program\'s open/full status are read from your own testing pages; without signing in you check them yourself.</string>
